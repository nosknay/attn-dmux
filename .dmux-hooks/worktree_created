#!/bin/bash
set -e
source "$DMUX_ROOT/.dmux-hooks/lib/attentive.sh"

cd "$DMUX_WORKTREE_PATH"

REPO_TYPE=$(detect_repo_type)

if [ "$REPO_TYPE" = "java" ]; then
  make githooks
elif [ "$REPO_TYPE" = "frontend" ]; then
  yarn install --frozen-lockfile &
  yarn prepare
fi

for f in .env.local .env.development; do
  [ -f "$DMUX_ROOT/$f" ] && cp "$DMUX_ROOT/$f" "$DMUX_WORKTREE_PATH/$f"
done

# Write WAL instructions for each agent type.
# Each agent reads a different instruction file; we write all of them so any
# enabled agent in this pane gets the coordination context automatically.
WAL_SECTION='## WAL — inter-agent coordination

Other agents may be working in parallel panes. Use the WAL helpers to coordinate:

```
source "$DMUX_ROOT/.dmux-hooks/lib/attentive.sh"

wal_write "intent"    "about to modify AccountService.java"    # signal intent before touching shared files
wal_write "discovery" "param store key /prod/db-url is unused" # share findings with other agents
wal_write "blocked"   "waiting on JNY-5678 to merge"           # signal blockers
wal_write "done"      "PR opened: $DMUX_SLUG"                  # signal completion

wal_read                        # see what other agents have written this session
wal_history "jiraKey=JNY-1234"  # query findings from previous sessions
```

Call `wal_read` on demand — just before you need the context (before acting on a file, before giving feedback). Do not call it at startup.'

# Claude Code — .claude/CLAUDE.md (never tracked, Claude-specific dir)
mkdir -p "$DMUX_WORKTREE_PATH/.claude"
printf '%s\n' "$WAL_SECTION" > "$DMUX_WORKTREE_PATH/.claude/CLAUDE.md"

# Codex — AGENTS.md / Gemini CLI — GEMINI.md (append if exists, create if not)
for agent_file in AGENTS.md GEMINI.md; do
  target="$DMUX_WORKTREE_PATH/$agent_file"
  if [ -f "$target" ]; then
    grep -q "WAL — inter-agent" "$target" || printf '\n%s\n' "$WAL_SECTION" >> "$target"
  else
    printf '%s\n' "$WAL_SECTION" > "$target"
  fi
done

echo "[Hook] Worktree ready: $DMUX_SLUG ($REPO_TYPE)"
