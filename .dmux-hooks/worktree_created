#!/bin/bash
set -e
source "$DMUX_ROOT/.dmux-hooks/lib/attentive.sh"

cd "$DMUX_WORKTREE_PATH"

REPO_TYPE=$(detect_repo_type)

if [ "$REPO_TYPE" = "java" ]; then
  make githooks
elif [ "$REPO_TYPE" = "frontend" ]; then
  yarn install --frozen-lockfile &
  yarn prepare
fi

for f in .env.local .env.development; do
  [ -f "$DMUX_ROOT/$f" ] && cp "$DMUX_ROOT/$f" "$DMUX_WORKTREE_PATH/$f"
done

# Append WAL instructions to CLAUDE.md so the agent knows how to coordinate
if [ -f "$DMUX_WORKTREE_PATH/CLAUDE.md" ]; then
  cat >> "$DMUX_WORKTREE_PATH/CLAUDE.md" <<'EOF'

## WAL — inter-agent coordination

Other agents may be working in parallel panes. Use the WAL helpers to coordinate:

```bash
source "$DMUX_ROOT/.dmux-hooks/lib/attentive.sh"

wal_write "intent"    "about to modify AccountService.java"    # signal intent before touching shared files
wal_write "discovery" "param store key /prod/db-url is unused" # share findings with other agents
wal_write "blocked"   "waiting on JNY-5678 to merge"           # signal blockers
wal_write "done"      "PR opened: $DMUX_SLUG"                  # signal completion

wal_read                        # see what other agents have written this session
wal_history "jiraKey=JNY-1234"  # query findings from previous sessions
```
EOF
fi

echo "[Hook] Worktree ready: $DMUX_SLUG ($REPO_TYPE)"
